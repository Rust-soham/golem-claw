{
	"type": "module",
	"scripts": {
		"build": "tsc",
		"dev": "tsx watch --env-file=.env src/bot.ts",
		"prestart": "pnpm run build",
		"typecheck": "tsc --noEmit",
		"typecheck:watch": "tsc --noEmit --watch",
		"start": "node --env-file=.env dist/bot.js"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"effect": "4.0.0-beta.66",
		"grammy": "^1.42.0"
	}
}
